# Claude API 키 (총괄 AI 분석용) - https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# 분석 모델 (기본 유지 권장. 품질 우선이면 claude-opus-4-8 등으로 변경)
AI_TEAM_MODEL=claude-sonnet-4-6

# ZIANTGYM+ 데이터베이스 (Neon/Postgres) 연결 문자열.
# 없으면 샘플 데이터로 동작하며, 실제 분석을 원하면 넣으세요.
DATABASE_URL=

# 총괄 AI가 자동 분석을 도는 시간 (cron 형식). 기본: 매일 09:00
DAILY_CRON=0 9 * * *
